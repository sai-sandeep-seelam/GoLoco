{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // ⚠ In production, set this via Azure App Service → Configuration → Connection Strings
    // Name: DefaultConnection | Type: SQLAzure
    // The environment variable equivalent is: SQLAZURECONNSTR_DefaultConnection
    "DefaultConnection": ""
  },
  "JwtSettings": {
    // ⚠ In production, set all three via Azure App Service → Configuration → Application Settings
    // Keys: JwtSettings__Key | JwtSettings__Issuer | JwtSettings__Audience
    "Key": "",
    "Issuer": "OnlineEventTicketManagementAPI",
    "Audience": "OnlineEventTicketManagementClient",
    "DurationInMinutes": 120
  },
  "AzureBlobStorage": {
    // ⚠ In production, set via Azure App Service → Configuration → Application Settings
    // Keys: AzureBlobStorage__ConnectionString | AzureBlobStorage__ContainerName
    "ConnectionString": "",
    "ContainerName": "event-images"
  },
  "AllowedOrigins": [
    // ⚠ In production, add your deployed frontend URL here via Application Settings:
    // Key: AllowedOrigins__0 | Value: https://your-frontend.azurestaticapps.net
    "http://localhost:5174"
  ]
}
